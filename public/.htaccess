<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve real files and directories as-is (assets, /api, /uploads, images).
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else is handled by the single-page app.
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On

  # Vite fingerprints these filenames, so a new build is a new URL and the old
  # ones can be cached indefinitely.
  <FilesMatch "\.(js|css|svg|woff2?|ttf|otf|eot)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>

  <FilesMatch "\.(jpg|jpeg|png|gif|webp|avif|ico)$">
    ExpiresDefault "access plus 30 days"
  </FilesMatch>

  # index.html names the hashed bundles, so it must not be cached or the site
  # would keep loading the previous build after a deploy.
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 0 seconds"
  </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|svg|woff2?|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
